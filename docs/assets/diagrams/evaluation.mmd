flowchart LR
    subgraph L12["learned-behaviour benches"]
        direction TB
        A("① held-out bench<br/>0.87 vs 0.64 ceiling")
        B("② actor bench<br/>style lift")
    end

    C("③ e2e gate<br/>self-rollout games")
    M("🔧 machinery<br/>checks")
